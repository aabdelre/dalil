<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <title>{{companyName}} — Customer Story</title>
  <style>
    @page { size: Letter; }
    :root {
      --ink: #0f172a;
      --muted: #475569;
      --accent: #0ea5e9;
      --bg: #f8fafc;
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, system-ui, sans-serif;
      color: var(--ink);
      margin: 0;
      padding: 36px 40px;
      line-height: 1.45;
    }
    header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      border-bottom: 2px solid var(--accent);
      padding-bottom: 12px;
      margin-bottom: 18px;
    }
    header .brand {
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-size: 11px;
      color: var(--muted);
    }
    header .label {
      font-size: 11px;
      color: var(--muted);
    }
    h1 {
      font-size: 26px;
      line-height: 1.2;
      margin: 0 0 6px 0;
    }
    .subtitle {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 22px;
    }
    h2 {
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin: 20px 0 8px 0;
    }
    .metric-grid {
      display: grid;
      grid-template-columns: repeat({{metricColumns}}, 1fr);
      gap: 10px;
      margin: 6px 0 6px 0;
    }
    .metric {
      background: var(--bg);
      border-radius: 8px;
      padding: 12px 14px;
    }
    .metric .value {
      font-size: 20px;
      font-weight: 700;
      color: var(--ink);
    }
    .metric .label {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
    }
    .metric .timeframe {
      font-size: 10px;
      color: var(--muted);
      margin-top: 4px;
      font-style: italic;
    }
    .body {
      font-size: 12.5px;
    }
    .body p {
      margin: 6px 0;
    }
    blockquote {
      margin: 16px 0;
      padding: 14px 18px;
      border-left: 3px solid var(--accent);
      background: var(--bg);
      font-size: 13px;
      font-style: italic;
    }
    blockquote .author {
      display: block;
      margin-top: 8px;
      font-style: normal;
      font-size: 11px;
      color: var(--muted);
    }
    footer {
      position: fixed;
      bottom: 18px;
      left: 40px;
      right: 40px;
      font-size: 10px;
      color: var(--muted);
      display: flex;
      justify-content: space-between;
      border-top: 1px solid #e2e8f0;
      padding-top: 6px;
    }
  </style>
</head>
<body>
  <header>
    <div class="brand">Dalil · Customer Story</div>
    <div class="label">{{industry}}{{#if sizeSegment}} · {{sizeSegment}}{{/if}}</div>
  </header>

  <h1>{{headline}}</h1>
  <div class="subtitle">{{companyName}}{{#if useCases}} · {{useCases}}{{/if}}</div>

  <h2>At a glance</h2>
  <div class="metric-grid">
    {{#each outcomes}}
    <div class="metric">
      <div class="value">{{value}}</div>
      <div class="label">{{metric}}</div>
      {{#if timeframe}}<div class="timeframe">{{timeframe}}</div>{{/if}}
    </div>
    {{/each}}
  </div>

  <h2>The story</h2>
  <div class="body">
    {{{bodyHtml}}}
  </div>

  {{#if quote}}
  <blockquote>
    "{{quote.text}}"
    <span class="author">— {{quote.authorName}}{{#if quote.authorTitle}}, {{quote.authorTitle}}{{/if}}</span>
  </blockquote>
  {{/if}}

  <footer>
    <span>Generated by Dalil</span>
    <span>{{companyName}}</span>
  </footer>
</body>
</html>
